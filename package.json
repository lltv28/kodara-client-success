{
  "name": "kodara-client-success",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "node server/index.js",
    "dev:client": "vite --config client/vite.config.js",
    "build": "vite build --config client/vite.config.js",
    "start": "NODE_ENV=production node server/index.js",
    "add-user": "node server/scripts/add-user.js",
    "test": "npm run copy-prompts && vitest run",
    "test:watch": "npm run copy-prompts && vitest",
    "copy-prompts": "node -e \"import fs from 'fs';import path from 'path';const src='master-prompts';const dest='server/prompts';fs.mkdirSync(dest,{recursive:true});fs.readdirSync(src).forEach(f=>fs.copyFileSync(path.join(src,f),path.join(dest,f.replace(/^\\d+ - /,''))))\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "connect-sqlite3": "^0.9.16",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "marked": "^17.0.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.0",
    "supertest": "^7.2.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
